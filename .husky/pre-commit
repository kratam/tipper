#!/bin/sh
output=$(npx biome check --reporter=summary 2>&1)
exit_code=$?

if [ $exit_code -ne 0 ]; then
  echo "$output"
  echo ""
  echo "❌  Biome check failed — commit blocked."
  echo "    Futtasd: npx biome check --write ."
  exit 1
fi

# Biome az info szintű hibákra nem ad vissza exit code 1-et,
# ezért külön ellenőrizzük, hogy van-e bármilyen szintű hiba
if echo "$output" | grep -qE "^Found [1-9][0-9]* (error|warning|info)"; then
  echo "$output"
  echo ""
  echo "❌  Biome check failed — commit blocked."
  echo "    Futtasd: npx biome check --write ."
  exit 1
fi

exit 0
